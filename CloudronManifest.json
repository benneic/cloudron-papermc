{
  "id": "io.cloudron.papermc",
  "title": "PaperMC Minecraft Server",
  "author": "Benn <benn@cloudron.papermc>",
  "description": "file://DESCRIPTION.md",
  "changelog": "file://CHANGELOG",
  "tagline": "High-performance Minecraft server with web console",
  "version": "1.0.0",
  "upstreamVersion": "1.21.11",
  "healthCheckPath": "/",
  "httpPort": 3000,
  "tcpPorts": {
    "MINECRAFT_PORT": {
      "title": "Minecraft Server Port",
      "description": "TCP port for Minecraft Java Edition client connections",
      "defaultValue": 25565,
      "containerPort": 25565,
      "enabledByDefault": true
    }
  },
  "udpPorts": {
    "GEYSER_PORT": {
      "title": "Geyser Bedrock Port",
      "description": "UDP port for Minecraft Bedrock Edition client connections via Geyser",
      "defaultValue": 19132,
      "containerPort": 19132,
      "enabledByDefault": true
    }
  },
  "addons": {
    "localstorage": {},
    "oidc": {
      "loginRedirectUri": "/auth/callback",
      "logoutRedirectUri": "/"
    },
    "scheduler": {
      "papermc_auto_update": {
        "schedule": "0 */6 * * *",
        "command": "/app/code/scripts/auto-update.sh >> /app/data/papermc-update.log 2>&1"
      }
    }
  },
  "manifestVersion": 2,
  "optionalSso": true,
  "memoryLimit": 2147483648,
  "website": "https://papermc.io",
  "contactEmail": "support@cloudron.io",
  "icon": "file://icon.png",
  "tags": [
    "games",
    "minecraft"
  ],
  "postInstallMessage": "file://POSTINSTALL.md",
  "mediaLinks": []
}
